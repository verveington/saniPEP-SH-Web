# Production-like compose example.
# Copy values from your secret store or deployment environment. Do not commit real secrets.

WEB_PORT=3000
BACKEND_PORT=4100

NEXT_PUBLIC_SITE_URL=https://www.example-sanitaetshaus.de
NEXT_PUBLIC_PORTAL_BACKEND_URL=https://api.example-sanitaetshaus.de
VITE_PORTAL_BACKEND_URL=https://api.example-sanitaetshaus.de
STRAPI_API_URL=
STRAPI_API_TOKEN=

PORTAL_BACKEND_BASE_URL=https://api.example-sanitaetshaus.de
TRUSTED_ORIGINS=https://www.example-sanitaetshaus.de

POSTGRES_USER=sanipep_app
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_DB=sanipep_portal
PORTAL_DATABASE_URL=postgres://sanipep_app:replace-with-strong-postgres-password@postgres:5432/sanipep_portal
PORTAL_DATABASE_SSL=true
POSTGRES_POOL_MAX=10

REDIS_URL=redis://redis:6379
REDIS_TLS=false
REDIS_KEY_PREFIX=sanipep:portal

PORTAL_SESSION_COOKIE_NAME=__Host-sanipep_portal_session
PORTAL_SESSION_SECRET=replace-with-at-least-32-random-characters
CSRF_SECRET=replace-with-at-least-32-random-characters
PORTAL_OTP_HASH_SECRET=replace-with-at-least-32-random-characters
PORTAL_PASSWORD_PEPPER=replace-with-at-least-32-random-characters
AUDIT_LOG_HASH_SECRET=replace-with-at-least-32-random-characters

UPLOAD_QUARANTINE_BUCKET=replace-with-quarantine-bucket-name
UPLOAD_CLEAN_BUCKET=replace-with-clean-bucket-name
UPLOAD_KMS_KEY_ID=replace-with-kms-key-id
AV_SCANNER_MODE=managed
AV_SCANNER_ENDPOINT=https://av-scanner.example.internal

OMNIA_WRITE_MODE=read_only
