# Staging compose example for Public Requests + Staff Admin MVP.
# Copy to .env.staging and replace all placeholder values from the staging secret store.
# Do not commit .env.staging or real secrets.

WEB_PORT=3000
BACKEND_PORT=4100
STAFF_ADMIN_PORT=5184
STAGING_HTTP_PORT=80
STAGING_HTTPS_PORT=443
BACKEND_NODE_ENV=production

# Replace all .invalid placeholders below with domains you own before public staging use.
# Do not deploy placeholder domains as real targets.
# Earlier *.example-sanitaetshaus.de values were placeholders too and are not owned staging domains.
# Public HTTPS staging requires owned DNS names, reachable DNS records and valid TLS.
STAGING_WEB_HOST=replace-with-owned-web-staging-host.invalid
STAGING_STAFF_HOST=replace-with-owned-staff-staging-host.invalid
STAGING_API_HOST=replace-with-owned-api-staging-host.invalid
NEXT_PUBLIC_SITE_URL=https://replace-with-owned-web-staging-host.invalid
NEXT_PUBLIC_PORTAL_BACKEND_URL=https://replace-with-owned-api-staging-host.invalid
VITE_PORTAL_BACKEND_URL=https://replace-with-owned-api-staging-host.invalid
# Vite embeds VITE_PORTAL_BACKEND_URL into the Staff Admin bundle. Rebuild staff-admin after changing it.
STAFF_ADMIN_PUBLIC_URL=https://replace-with-owned-staff-staging-host.invalid
STRAPI_API_URL=
STRAPI_API_TOKEN=

PORTAL_BACKEND_BASE_URL=https://replace-with-owned-api-staging-host.invalid
TRUSTED_ORIGINS=https://replace-with-owned-web-staging-host.invalid,https://replace-with-owned-staff-staging-host.invalid

POSTGRES_USER=sanipep_app
POSTGRES_PASSWORD=replace-with-staging-postgres-password
POSTGRES_DB=sanipep_portal
PORTAL_DATABASE_URL=postgres://sanipep_app:replace-with-staging-postgres-password@postgres:5432/sanipep_portal
PORTAL_DATABASE_SSL=false
POSTGRES_POOL_MAX=10
PORTAL_REPOSITORY_DRIVER=postgres

REDIS_URL=redis://redis:6379
REDIS_TLS=false
REDIS_KEY_PREFIX=sanipep:portal:staging

PORTAL_SESSION_COOKIE_NAME=__Host-sanipep_portal_session
PORTAL_SESSION_SECRET=replace-with-at-least-32-random-characters
CSRF_SECRET=replace-with-at-least-32-random-characters
PORTAL_OTP_HASH_SECRET=replace-with-at-least-32-random-characters
PORTAL_PASSWORD_PEPPER=replace-with-at-least-32-random-characters
AUDIT_LOG_HASH_SECRET=replace-with-at-least-32-random-characters

MAIL_ENABLED=false
MAIL_FROM_ADDRESS=sani@sanipep.de
MAIL_FROM_NAME=saniPEP Sanitaetshaus
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=

# Controlled pilot default: Uploads are explicitly disabled.
# Public document requests remain metadata-only and no upload object/file is created.
# Set UPLOADS_ENABLED=true only after quarantine, AV, KMS, retention and access-control approval.
UPLOADS_ENABLED=false
UPLOAD_QUARANTINE_BUCKET=
UPLOAD_CLEAN_BUCKET=
UPLOAD_KMS_KEY_ID=
AV_SCANNER_MODE=stub-disabled
AV_SCANNER_ENDPOINT=

OMNIA_WRITE_MODE=read_only

# CMS is not part of the Public-Request/Staff-Admin staging MVP.
CMS_POSTGRES_USER=sanipep_cms
CMS_POSTGRES_PASSWORD=replace-with-staging-cms-postgres-password
CMS_POSTGRES_DB=sanipep_cms
CMS_APP_KEYS=replace-with-cms-app-key-1,replace-with-cms-app-key-2,replace-with-cms-app-key-3,replace-with-cms-app-key-4
CMS_ADMIN_JWT_SECRET=replace-with-at-least-32-random-characters
CMS_API_TOKEN_SALT=replace-with-at-least-32-random-characters
CMS_TRANSFER_TOKEN_SALT=replace-with-at-least-32-random-characters
CMS_JWT_SECRET=replace-with-at-least-32-random-characters
CMS_ENCRYPTION_KEY=replace-with-32-character-encryption-key
CMS_CORS_ORIGINS=https://replace-with-owned-web-staging-host.invalid
CMS_UPLOAD_SIZE_LIMIT=10485760
