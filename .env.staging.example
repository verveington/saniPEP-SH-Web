# Staging compose example for Public Requests + Staff Admin MVP.
# Copy to .env.staging and replace all placeholder values from the staging secret store.
# Do not commit .env.staging or real secrets.

WEB_PORT=3000
BACKEND_PORT=4100
STAFF_ADMIN_PORT=5184

NEXT_PUBLIC_SITE_URL=https://staging.example-sanitaetshaus.de
NEXT_PUBLIC_PORTAL_BACKEND_URL=https://api-staging.example-sanitaetshaus.de
VITE_PORTAL_BACKEND_URL=https://api-staging.example-sanitaetshaus.de
STAFF_ADMIN_PUBLIC_URL=https://staff-staging.example-sanitaetshaus.de
STRAPI_API_URL=
STRAPI_API_TOKEN=

PORTAL_BACKEND_BASE_URL=https://api-staging.example-sanitaetshaus.de
TRUSTED_ORIGINS=https://staging.example-sanitaetshaus.de,https://staff-staging.example-sanitaetshaus.de

POSTGRES_USER=sanipep_app
POSTGRES_PASSWORD=replace-with-staging-postgres-password
POSTGRES_DB=sanipep_portal
PORTAL_DATABASE_URL=postgres://sanipep_app:replace-with-staging-postgres-password@postgres:5432/sanipep_portal
PORTAL_DATABASE_SSL=false
POSTGRES_POOL_MAX=10
PORTAL_REPOSITORY_DRIVER=postgres

REDIS_URL=redis://redis:6379
REDIS_TLS=false
REDIS_KEY_PREFIX=sanipep:portal:staging

PORTAL_SESSION_COOKIE_NAME=__Host-sanipep_portal_session
PORTAL_SESSION_SECRET=replace-with-at-least-32-random-characters
CSRF_SECRET=replace-with-at-least-32-random-characters
PORTAL_OTP_HASH_SECRET=replace-with-at-least-32-random-characters
PORTAL_PASSWORD_PEPPER=replace-with-at-least-32-random-characters
AUDIT_LOG_HASH_SECRET=replace-with-at-least-32-random-characters

# Upload infrastructure stays configured only for readiness planning.
# Public document requests remain metadata-only and no upload object/file is created.
UPLOAD_QUARANTINE_BUCKET=replace-with-disabled-staging-quarantine-bucket
UPLOAD_CLEAN_BUCKET=replace-with-disabled-staging-clean-bucket
UPLOAD_KMS_KEY_ID=replace-with-disabled-staging-kms-key-id
AV_SCANNER_MODE=managed
AV_SCANNER_ENDPOINT=https://av-scanner-staging.example.internal

OMNIA_WRITE_MODE=read_only

# CMS is not part of the Public-Request/Staff-Admin staging MVP.
CMS_POSTGRES_USER=sanipep_cms
CMS_POSTGRES_PASSWORD=replace-with-staging-cms-postgres-password
CMS_POSTGRES_DB=sanipep_cms
CMS_APP_KEYS=replace-with-cms-app-key-1,replace-with-cms-app-key-2,replace-with-cms-app-key-3,replace-with-cms-app-key-4
CMS_ADMIN_JWT_SECRET=replace-with-at-least-32-random-characters
CMS_API_TOKEN_SALT=replace-with-at-least-32-random-characters
CMS_TRANSFER_TOKEN_SALT=replace-with-at-least-32-random-characters
CMS_JWT_SECRET=replace-with-at-least-32-random-characters
CMS_ENCRYPTION_KEY=replace-with-32-character-encryption-key
CMS_CORS_ORIGINS=https://staging.example-sanitaetshaus.de
CMS_UPLOAD_SIZE_LIMIT=10485760
