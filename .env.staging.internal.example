# Internal LAN/VPN staging example for the Public Requests + Staff Admin MVP.
# Copy to .env.staging.internal and replace placeholder secrets from the internal secret store.
# Do not commit .env.staging.internal or real secrets.
#
# This file is only for an internal server-IP test on 10.0.60.13.
# It is not a public staging or production configuration.

WEB_PORT=3000
BACKEND_PORT=4100
STAFF_ADMIN_PORT=5184

# The backend code intentionally rejects http:// origins when NODE_ENV=production.
# This explicit internal override keeps the production default untouched while allowing
# a LAN/VPN-only HTTP smoke test over the server IP.
BACKEND_NODE_ENV=development

NEXT_PUBLIC_SITE_URL=http://10.0.60.13:3000
NEXT_PUBLIC_PORTAL_BACKEND_URL=http://10.0.60.13:4100
VITE_PORTAL_BACKEND_URL=http://10.0.60.13:4100
# Vite embeds VITE_PORTAL_BACKEND_URL into the Staff Admin bundle. Rebuild staff-admin after changing it.
STAFF_ADMIN_PUBLIC_URL=http://10.0.60.13:5184
STRAPI_API_URL=
STRAPI_API_TOKEN=

PORTAL_BACKEND_BASE_URL=http://10.0.60.13:4100
TRUSTED_ORIGINS=http://10.0.60.13:3000,http://10.0.60.13:5184,http://10.0.60.13:5185

POSTGRES_USER=sanipep_app
POSTGRES_PASSWORD=replace-with-internal-staging-postgres-password
POSTGRES_DB=sanipep_portal
PORTAL_DATABASE_URL=postgres://sanipep_app:replace-with-internal-staging-postgres-password@postgres:5432/sanipep_portal
PORTAL_DATABASE_SSL=false
POSTGRES_POOL_MAX=10
PORTAL_REPOSITORY_DRIVER=postgres

REDIS_URL=redis://redis:6379
REDIS_TLS=false
REDIS_KEY_PREFIX=sanipep:portal:staging:internal

# HTTP-only internal tests cannot use __Host-* Secure cookies.
PORTAL_SESSION_COOKIE_NAME=sanipep_portal_internal_session
PORTAL_SESSION_SECRET=replace-with-at-least-32-random-characters
CSRF_SECRET=replace-with-at-least-32-random-characters
PORTAL_OTP_HASH_SECRET=replace-with-at-least-32-random-characters
PORTAL_PASSWORD_PEPPER=replace-with-at-least-32-random-characters
AUDIT_LOG_HASH_SECRET=replace-with-at-least-32-random-characters

# Upload infrastructure remains disabled/non-production for this MVP path.
# Public document requests remain metadata-only and no upload object/file is created.
UPLOAD_QUARANTINE_BUCKET=disabled-internal-staging-quarantine-bucket
UPLOAD_CLEAN_BUCKET=disabled-internal-staging-clean-bucket
UPLOAD_KMS_KEY_ID=disabled-internal-staging-kms-key-id
AV_SCANNER_MODE=stub-disabled
AV_SCANNER_ENDPOINT=

OMNIA_WRITE_MODE=read_only

# CMS is not part of the Public-Request/Staff-Admin staging MVP.
CMS_POSTGRES_USER=sanipep_cms
CMS_POSTGRES_PASSWORD=replace-with-internal-staging-cms-postgres-password
CMS_POSTGRES_DB=sanipep_cms
CMS_APP_KEYS=replace-with-cms-app-key-1,replace-with-cms-app-key-2,replace-with-cms-app-key-3,replace-with-cms-app-key-4
CMS_ADMIN_JWT_SECRET=replace-with-at-least-32-random-characters
CMS_API_TOKEN_SALT=replace-with-at-least-32-random-characters
CMS_TRANSFER_TOKEN_SALT=replace-with-at-least-32-random-characters
CMS_JWT_SECRET=replace-with-at-least-32-random-characters
CMS_ENCRYPTION_KEY=replace-with-32-character-encryption-key
CMS_CORS_ORIGINS=http://10.0.60.13:3000
CMS_UPLOAD_SIZE_LIMIT=10485760
