# saniPEP Portal Backend - development example only
# Do not commit production secrets. Keep production values in the hosting secret store.

NODE_ENV=development
PORT=4100
PORTAL_BACKEND_BASE_URL=http://localhost:4100
TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174

# PostgreSQL is optional for the scaffold but required before production.
PORTAL_DATABASE_URL=postgres://sanipep:sanipep-local@localhost:5432/sanipep_portal
PORTAL_DATABASE_SSL=false
POSTGRES_POOL_MAX=10
POSTGRES_IDLE_TIMEOUT_MS=30000
POSTGRES_CONNECTION_TIMEOUT_MS=5000
POSTGRES_STATEMENT_TIMEOUT_MS=15000

# Redis is optional for the scaffold but required before production sessions/rate limits.
REDIS_URL=redis://localhost:6379
REDIS_TLS=false
REDIS_KEY_PREFIX=sanipep:portal

PORTAL_SESSION_COOKIE_NAME=__Host-sanipep_portal_session
PORTAL_SESSION_IDLE_TTL_MINUTES=30
PORTAL_SESSION_ABSOLUTE_TTL_HOURS=12
PORTAL_SESSION_SECRET=development-only-change-in-secret-store
CSRF_SECRET=development-only-change-in-secret-store

PORTAL_OTP_TTL_DAYS=14
PORTAL_OTP_MAX_ATTEMPTS=5
PORTAL_OTP_HASH_SECRET=development-only-change-in-secret-store
PORTAL_PASSWORD_PEPPER=development-only-change-in-secret-store
PASSWORD_RESET_TTL_MINUTES=30
MAGIC_LINK_ENABLED=false

RATE_LIMIT_LOGIN_WINDOW_SECONDS=900
RATE_LIMIT_LOGIN_MAX_ATTEMPTS=5
RATE_LIMIT_UPLOAD_MAX_PER_HOUR=10
RATE_LIMIT_GLOBAL_WINDOW_SECONDS=60
RATE_LIMIT_GLOBAL_MAX_REQUESTS=120
ACCOUNT_LOCKOUT_MAX_ATTEMPTS=5
ACCOUNT_LOCKOUT_WINDOW_SECONDS=900
ACCOUNT_LOCKOUT_BASE_SECONDS=900
ACCOUNT_LOCKOUT_MAX_SECONDS=86400

UPLOAD_MAX_BYTES=20971520
UPLOAD_ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png,image/heic,image/heif
UPLOAD_QUARANTINE_BUCKET=sanipep-portal-quarantine-dev
UPLOAD_CLEAN_BUCKET=sanipep-portal-clean-dev
UPLOAD_KMS_KEY_ID=development-only-kms-key-id
UPLOAD_SIGNED_URL_TTL_SECONDS=300

# Stub mode must not be used in production.
AV_SCANNER_MODE=stub-disabled
AV_SCANNER_ENDPOINT=
AV_SCAN_TIMEOUT_SECONDS=30

UPLOAD_ABORTED_RETENTION_HOURS=24
UPLOAD_REJECTED_RETENTION_DAYS=7
UPLOAD_CLEAN_RETENTION_DAYS=30

AUDIT_LOG_SINK=database
AUDIT_LOG_HASH_SECRET=development-only-change-in-secret-store
AUDIT_LOG_RETENTION_DAYS=2555

OMNIA_API_BASE_URL=
OMNIA_CLIENT_ID=
OMNIA_CLIENT_SECRET=
OMNIA_WRITE_MODE=read_only

LOG_LEVEL=info
ERROR_TRACKING_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
