HOST=127.0.0.1
PORT=1337
APP_KEYS=replace-me-1,replace-me-2,replace-me-3,replace-me-4
API_TOKEN_SALT=replace-me-api-token-salt
ADMIN_JWT_SECRET=replace-me-admin-jwt-secret
TRANSFER_TOKEN_SALT=replace-me-transfer-token-salt
JWT_SECRET=replace-me-users-permissions-jwt-secret
ENCRYPTION_KEY=replace-me-32-character-encryption-key

# Development-only defaults. Production blocks SQLite and requires explicit CORS origins.
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db
CMS_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Production database settings.
# HOST=0.0.0.0
# DATABASE_CLIENT=postgres
# DATABASE_URL=postgres://user:password@host:5432/sanipep_cms
# DATABASE_SCHEMA=public
# DATABASE_SSL=false
# CMS_CORS_ORIGINS=https://www.example-sanitaetshaus.de

# Public website reads Strapi server-side. Prefer a read-only API token for production.
STRAPI_PUBLIC_READ_TOKEN=
PUBLIC_SITE_URL=http://localhost:3000

# Upload media library guardrails for editorial assets only.
UPLOAD_SIZE_LIMIT=10485760
STRAPI_TELEMETRY_DISABLED=true
