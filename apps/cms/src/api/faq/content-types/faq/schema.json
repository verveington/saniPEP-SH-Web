{
  "kind": "collectionType",
  "collectionName": "faqs",
  "info": {
    "singularName": "faq",
    "pluralName": "faqs",
    "displayName": "FAQ",
    "description": "Oeffentliche Fragen fuer Leistungen, Portal und Rezeptprozesse"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "question": {
      "type": "string",
      "required": true,
      "maxLength": 160
    },
    "answer": {
      "type": "richtext",
      "required": true
    },
    "safeTopic": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "termin",
        "rezeptupload",
        "kompression",
        "brustprothetik",
        "inkontinenz",
        "pflegehilfsmittel",
        "portal",
        "kontakt"
      ]
    },
    "relatedRoute": {
      "type": "component",
      "repeatable": false,
      "component": "shared.internal-link"
    },
    "claimSafe": {
      "type": "boolean",
      "required": true,
      "default": true
    },
    "sortOrder": {
      "type": "integer",
      "required": true,
      "default": 0
    }
  }
}
