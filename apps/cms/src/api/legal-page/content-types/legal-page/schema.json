{
  "kind": "collectionType",
  "collectionName": "legal_pages",
  "info": {
    "singularName": "legal-page",
    "pluralName": "legal-pages",
    "displayName": "Legal Page",
    "description": "Versionierte Rechtstexte fuer Datenschutz, Impressum und Einwilligungen"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 120
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "body": {
      "type": "richtext",
      "required": true
    },
    "placeholderNotice": {
      "type": "text",
      "required": true
    },
    "reviewStatus": {
      "type": "enumeration",
      "required": true,
      "default": "placeholder",
      "enum": [
        "placeholder",
        "legal-review",
        "approved"
      ]
    },
    "legalKind": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "privacy",
        "imprint",
        "consent",
        "terms"
      ]
    },
    "version": {
      "type": "string",
      "required": true,
      "maxLength": 40
    },
    "downloads": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "files"
      ]
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
}
