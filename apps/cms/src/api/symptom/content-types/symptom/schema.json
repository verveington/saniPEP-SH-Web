{
  "kind": "collectionType",
  "collectionName": "symptoms",
  "info": {
    "singularName": "symptom",
    "pluralName": "symptoms",
    "displayName": "Symptom",
    "description": "Patientensprache fuer Suche und qualifizierte Weiterleitung"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "term": {
      "type": "string",
      "required": true,
      "maxLength": 120
    },
    "category": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "symptom",
        "product",
        "situation"
      ]
    },
    "synonyms": {
      "type": "json"
    },
    "priority": {
      "type": "integer",
      "required": true,
      "default": 1
    },
    "recommendedRoute": {
      "type": "string",
      "required": true,
      "maxLength": 120
    },
    "primaryAction": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "appointment",
        "upload",
        "configure",
        "portal",
        "inquiry"
      ]
    },
    "analyticsGoal": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "appointment",
        "upload",
        "contact",
        "portal_login"
      ]
    },
    "trackingNote": {
      "type": "string",
      "required": true,
      "default": "Nur grobes Ziel tracken, keine Begriffe oder Diagnosen."
    }
  }
}
