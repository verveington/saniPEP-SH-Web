# Portal auth backend
PORTAL_SESSION_COOKIE_NAME=sanipep_portal_session
PORTAL_SESSION_TTL_MINUTES=720
PORTAL_OTP_TTL_MINUTES=10080
PORTAL_OTP_HASH_SECRET=replace-with-random-secret
PORTAL_PASSWORD_PEPPER=replace-with-random-secret
PORTAL_MAGIC_LINK_ENABLED=false

# Upload backend
UPLOAD_MAX_BYTES=20971520
UPLOAD_ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png,image/heic,image/heif
UPLOAD_QUARANTINE_BUCKET=sanipep-upload-quarantine
UPLOAD_CLEAN_BUCKET=sanipep-upload-clean
UPLOAD_KMS_KEY_ID=replace-with-kms-key-id
UPLOAD_AV_SCANNER_MODE=disabled-local-dev
UPLOAD_SIGNED_URL_TTL_SECONDS=300

# Audit and persistence
PORTAL_DATABASE_URL=postgres://user:password@host:5432/sanipep_portal
AUDIT_LOG_RETENTION_DAYS=3650
AUDIT_LOG_HASH_SECRET=replace-with-random-secret

# Omnia adapter boundary
OMNIA_API_BASE_URL=https://omnia.example.invalid
OMNIA_CLIENT_ID=replace-in-secret-store
OMNIA_CLIENT_SECRET=replace-in-secret-store
OMNIA_WRITE_MODE=disabled
