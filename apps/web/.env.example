# Public website canonical URL for metadata/canonicals.
NEXT_PUBLIC_SITE_URL=https://www.sanipep.de

# Optional Strapi CMS endpoint. If unset or unreachable, the public website uses the seed fallback.
STRAPI_API_URL=http://127.0.0.1:1337

# Optional read-only API token. Public read endpoints also work without a token after cms:seed.
STRAPI_API_TOKEN=
