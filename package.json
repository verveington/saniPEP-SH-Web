{
  "name": "sanipep-sh-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev apps/web",
    "dev:cms": "npm --prefix apps/cms run develop",
    "dev:frontend:vite": "vite --config apps/frontend/vite.config.ts",
    "dev:portal": "VITE_ENABLE_MOCK_AUTH=true vite --config apps/portal/vite.config.ts",
    "dev:admin": "VITE_ENABLE_MOCK_AUTH=true vite --config apps/admin/vite.config.ts",
    "dev:design-lab": "VITE_ENABLE_MOCK_AUTH=true VITE_MOCK_ROLE=admin vite --config apps/design-lab/vite.config.ts",
    "build": "node scripts/check-web-site-url.mjs --validate-current-env && next build apps/web --webpack",
    "build:backend": "tsc -p apps/backend/tsconfig.json",
    "build:cms": "npm --prefix apps/cms run build",
    "build:frontend:vite": "tsc -p apps/frontend/tsconfig.json && vite build --config apps/frontend/vite.config.ts",
    "build:portal:mock": "VITE_ENABLE_MOCK_AUTH=true tsc -p apps/portal/tsconfig.json && VITE_ENABLE_MOCK_AUTH=true vite build --config apps/portal/vite.config.ts",
    "build:admin": "tsc -p apps/admin/tsconfig.json && vite build --config apps/admin/vite.config.ts",
    "build:admin:mock": "VITE_ENABLE_MOCK_AUTH=true tsc -p apps/admin/tsconfig.json && VITE_ENABLE_MOCK_AUTH=true vite build --config apps/admin/vite.config.ts",
    "build:design-lab:mock": "VITE_ENABLE_MOCK_AUTH=true VITE_MOCK_ROLE=admin tsc -p apps/design-lab/tsconfig.json && VITE_ENABLE_MOCK_AUTH=true VITE_MOCK_ROLE=admin vite build --config apps/design-lab/vite.config.ts",
    "check:architecture": "node scripts/check-architecture.mjs",
    "check:backend": "npm run check:backend:migrations && tsc -p apps/shared/backend/tsconfig.json && tsc -p apps/backend/tsconfig.json --noEmit",
    "check:backend:migrations": "node scripts/check-backend-migrations.mjs",
    "check:backend:runtime": "tsc -p apps/backend/tsconfig.json --noEmit",
    "check:flows": "node scripts/check-flows.mjs",
    "check:pilot:env": "npm run build:backend && node scripts/check-pilot-env.mjs",
    "check:pilot:live": "node scripts/check-pilot-live-smoke.mjs",
    "check:pilot:readiness": "npm run build:backend && node scripts/check-pilot-readiness.mjs",
    "check:postgres:backup-restore": "node scripts/check-postgres-backup-restore.mjs",
    "check:public-requests": "node scripts/check-public-requests.mjs",
    "check:public-requests:postgres": "npm run build:backend && node scripts/check-public-requests-postgres.mjs",
    "check:responsive": "node scripts/check-responsive.mjs",
    "check:staff-admin:mvp": "npm run build:backend && node scripts/check-staff-admin-mvp.mjs",
    "check:staff-admin:users": "npm run build:backend && node scripts/check-staff-admin-user-management.mjs",
    "check:web:site-url": "node scripts/check-web-site-url.mjs",
    "cms:seed": "npm --prefix apps/cms run seed",
    "cms:icons:import": "npm --prefix apps/cms run icons:import",
    "migrate:backend": "npm run build:backend && node apps/backend/dist/db/migrations.js",
    "db:migrate": "npm run migrate:backend",
    "compose:up": "docker compose up -d --build",
    "compose:ps": "docker compose ps",
    "compose:logs": "docker compose logs -f",
    "compose:down": "docker compose down",
    "compose:staging:config": "docker compose --env-file .env.staging.example -f compose.yaml -f compose.staging.yaml --profile staff-admin config",
    "demo:portal-mvp": "node scripts/demo-portal-mvp.mjs",
    "dev:backend:compose": "docker compose -f apps/backend/docker-compose.yml up --build",
    "preview": "next start apps/web",
    "staff:provision": "npm run build:backend && node scripts/provision-staff-user.mjs",
    "start:backend": "node apps/backend/dist/main.js",
    "preview:frontend:vite": "vite preview --config apps/frontend/vite.config.ts"
  },
  "dependencies": {
    "lucide-react": "^1.18.0",
    "next": "^16.2.9",
    "pg": "^8.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "redis": "^6.0.0",
    "reshaped": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "playwright": "^1.61.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
